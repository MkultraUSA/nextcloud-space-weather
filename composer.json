{
    "name": "mkultrausa/nextcloud-space-weather",
    "description": "Real-time space weather monitoring dashboard for Nextcloud. Tracks KP index, solar flux, X-ray flux, aurora forecasts, HF band conditions, D-RAP absorption maps, SDO solar imagery, and satellite images from NOAA, NASA, and HamQSL.",
    "type": "project",
    "license": "AGPL-3.0-or-later",
    "authors": [
        {
            "name": "Kevin Watkins",
            "email": "k.watkins@me.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "nextcloud/ocp": "^27.0 || ^28.0 || ^29.0 || ^30.0 || ^31.0 || ^33.0 || ^34.0 || ^35.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "nextcloud/coding-standard": "^1.0",
        "psalm/phar": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "OCA\\SpaceWeather\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OCA\\SpaceWeather\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "nextcloud/coding-standard": true
        }
    }
}
